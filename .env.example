# Copy to .env and fill in secrets.
GROQ_API_KEY=

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=robot_memory

QDRANT_URI=http://localhost:6333

WHISPER_MODEL_SIZE=small
# auto = Arabic + English detection; or force en / ar
WHISPER_LANGUAGE=auto
# auto | cuda | cpu — RTX 3060: use auto or cuda
ROBOT_DEVICE=auto
UNKNOWN_APPEAR_STABILIZE_SECONDS=1.0
SPEAKER_ONLY_WHEN_SPEAKING=true
LIP_SPEAKER_MOTION_THRESHOLD=0.22
FACE_MODEL_PATH=models/yolov8n-face.pt
OBJECT_MODEL_PATH=models/yolov8n.pt
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

VISION_INTERVAL=0.3
FACE_THRESHOLD=0.65
UNKNOWN_IDLE_SECONDS=5.0

SILENCE_THRESHOLD=0.02
SILENCE_DURATION=0.8
MAX_CHUNK_DURATION=30.0
WHISPER_BEAM_SIZE=5
WHISPER_TASK=transcribe
WHISPER_LOG_PROB_THRESHOLD=-1.0
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
WHISPER_NO_SPEECH_THRESHOLD=0.6
SEARCH_CONTEXT_MAX_CHARS=420
SEARCH_EXPANSION_MAX_LENGTH=220

STM_MAX_MESSAGES=5
SESSION_TIMEOUT_SECONDS=60
CAMERA_INDEX=0
ROBOT_IP=192.168.1.18
